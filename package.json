{
  "name": "enfieldgaragevietnam-frontend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create enfieldgaragevietnam-db",
    "d1:migrate:local": "wrangler d1 migrations apply enfieldgaragevietnam-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply enfieldgaragevietnam-db --remote",
    "d1:seed:local": "wrangler d1 execute enfieldgaragevietnam-db --local --file=./migrations/0002_seed.sql",
    "d1:seed:remote": "wrangler d1 execute enfieldgaragevietnam-db --remote --file=./migrations/0002_seed.sql",
    "r2:create": "wrangler r2 bucket create enfieldgaragevietnam-images"
  },
  "devDependencies": {
    "wrangler": "latest"
  }
}
